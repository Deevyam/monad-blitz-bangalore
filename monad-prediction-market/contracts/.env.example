# Private key of the deployer / market owner account (no 0x prefix is fine,
# but with 0x also works). This account must hold testnet MON for gas.
# Get testnet MON from the faucet at https://testnet.monad.xyz
PRIVATE_KEY=your_private_key_here

# Set automatically by the deploy script output. Paste the deployed factory
# address here so `npm run demo` can find it.
FACTORY_ADDRESS=
